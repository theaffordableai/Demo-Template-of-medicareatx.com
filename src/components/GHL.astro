---
// GHL integration (per GHL-INTEGRATION-STANDARD.md), now CONSENT-GATED.
// Nothing fires until the visitor opts in via the cookie manager (Consent.astro):
//  · analytics consent  → tracking beacon
//  · marketing consent  → chat/voice widget (still lazy-loaded on first interaction)
// Required for HIPAA/CIPA on a Medicare site — no client-side pixel before consent.
import { site } from "../config/site.config";
const g = site.ghl;
const realTracking = g.trackingId && !g.trackingId.includes("DEMO");
const realChat = g.enableChat && g.locationId && !g.locationId.includes("DEMO");
---
<script is:inline define:vars={{ realTracking, realChat, src: realTracking ? `https://${g.trackingDomain}/js/external-tracking.js` : "", tid: g.trackingId, loc: g.locationId }}>
(function(){
  var trackingDone=false, chatArmed=false, chatDone=false;

  function loadBeacon(){
    if(trackingDone || !realTracking) return; trackingDone=true;
    var s=document.createElement("script"); s.src=src; s.async=true;
    s.setAttribute("data-tracking-id", tid); document.body.appendChild(s);
  }
  function loadChat(){
    if(chatDone || !realChat) return; chatDone=true;
    var el=document.createElement("chat-widget");
    el.setAttribute("location-id", loc);
    el.style.setProperty("--chat-widget-primary-color","#1d5082");
    el.style.setProperty("--chat-widget-active-color","#1d5082");
    document.body.appendChild(el);
    var s=document.createElement("script");
    s.src="https://widgets.leadconnectorhq.com/loader.js";
    s.setAttribute("data-resources-url","https://widgets.leadconnectorhq.com/chat-widget/loader.js");
    document.body.appendChild(s);
  }
  function armChat(){
    if(chatArmed) return; chatArmed=true;
    ["scroll","mousemove","touchstart","click"].forEach(function(e){
      window.addEventListener(e, loadChat, { once:true, passive:true }); });
    setTimeout(loadChat, 6000);
  }

  // Contract the Consent manager calls.
  window.__applyConsent=function(cats){
    cats=cats||{};
    if(cats.analytics) loadBeacon();
    if(cats.marketing) armChat();
  };
  window.__loadTracking=function(){ loadBeacon(); armChat(); };

  // If consent was already granted on a previous visit, apply it now
  // (handles the case where Consent.astro ran before this script registered).
  try{
    var s=JSON.parse(localStorage.getItem("cookie-consent-v2")||"null");
    if(s) window.__applyConsent({analytics:!!s.analytics, marketing:!!s.marketing});
    else if(window.__consentCats) window.__applyConsent(window.__consentCats);
  }catch(e){}
})();
</script>
{!realChat && (
  <!-- GHL chat widget: set ghl.locationId in site.config.ts to enable (demo placeholder active). -->
)}
