---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site.config";
import { posts } from "../lib/posts";
const latest = posts.slice(0, 3);
const b = site.brand;
const props = [
  { t: "Navigate Medicare “red tape”", d: "Parts A, B, C and D, deadlines and paperwork — we translate it all into plain English and handle the legwork." },
  { t: "Understand all your options", d: "Advantage, Supplement (Medigap) and Part D, compared side by side so you can choose with confidence." },
  { t: "Avoid lifetime “gotcha” penalties", d: "Miss a window and you can pay more for the rest of your life. We make sure you enroll on time, every time." },
  { t: "A custom plan for lifetime care", d: "We match coverage to your doctors, prescriptions and budget — and review it every year as your needs change." },
];
const steps = [
  { n: "1", t: "Schedule a free conversation", d: "Tell us your doctors, prescriptions and budget. No cost, no pressure — ever." },
  { n: "2", t: "Get a personal plan comparison", d: "We compare the Medicare Advantage, Medigap and Part D plans we offer against your needs." },
  { n: "3", t: "Enroll & get ongoing support", d: "We handle enrollment and stay your local advisor for claims, appeals and annual reviews." },
];
const services = [
  ["Medicare Enrollment Assistance", "Turning 65 or new to Medicare — we guide every step of your Initial Enrollment."],
  ["Plan Comparison", "Advantage vs. Supplement vs. Part D, compared for your exact situation."],
  ["Annual Coverage Review", "Plans change yearly. We check yours every fall so you never overpay."],
  ["Claims Support & Appeals", "A real, local advocate for when something goes wrong."],
  ["Keep Your Doctor", "We help confirm your providers and prescriptions are covered before you switch."],
  ["Drug Cost Review", "Make sure your prescriptions are covered at the best possible price."],
];
const products = ["Medicare Advantage", "Medicare Supplement (Medigap)", "Part D Prescription Drug Plans", "Dental, Vision & Hearing", "Hospital Indemnity", "Life & Final Expense"];
const faqs = [
  { q: "What if I’m already on Medicare?", a: "We can still help — at no cost. We’ll review your current coverage, check that your doctors and prescriptions are covered, and compare it against the plans we offer to see if you could be paying less or getting more." },
  { q: "Do you charge for your time?", a: "No. Insurance companies pay our fee, so you don’t pay a thing for our services. You get unbiased, local guidance at no cost to you." },
  { q: "What are “lifetime penalties”?", a: "If you don’t enroll in Medicare Part B or Part D when you’re first eligible (and don’t have other qualifying coverage), you can owe a permanent late-enrollment penalty added to your premium for as long as you have Medicare. We make sure you enroll in the right window so you avoid them." },
  { q: "Is it true I could lose my doctor?", a: "Some Medicare Advantage plans use provider networks, so the wrong plan could mean your doctor is out of network. Before you enroll, we confirm your physicians and prescriptions are covered by the plan you choose." },
  { q: "What about additional coverages?", a: "Beyond core Medicare, we can help with dental, vision and hearing, hospital indemnity, and life or final-expense coverage — so the gaps Medicare leaves are covered too." },
];
const title = `${b.name} — Medicare made easy`;
const description = `${b.name}: free, expert Medicare guidance from ${b.advisorName} across ${b.serviceArea}. Compare and enroll in Medicare Advantage, Medigap and Part D — at no cost to you.`;
---
<BaseLayout {title} {description} pageType="home" path="/" {faqs}>
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="wrap herogrid">
      <div class="hero-text">
        <p class="eyebrow">Independent Medicare help · {b.foundedCity}, {b.state}</p>
        <h1 class="hero-h1">Medicare <span class="hl">made easy.</span></h1>
        <p class="lede">We educate and guide you through every step of the process to help you enroll in a Medicare plan that best fits your needs. <strong>Insurance companies pay our fee — so you pay nothing for our services.</strong></p>
        <div class="hero-cta-row">
          <a class="btn btn-accent" href="/contact">Schedule a conversation</a>
          <a class="btn btn-ghost" href="/about">Meet {b.advisorName}</a>
        </div>
        <div class="hero-trust">
          <span class="badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> $0 cost to you</span>
          <span class="badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Decades of experience</span>
          <span class="badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Local & independent</span>
        </div>
      </div>
      <figure class="hero-photo">
        <img src="/img/mike-advisor.png" width="600" height="800" alt={`${b.advisorName}, ${b.advisorTitle} at ${b.name}`} />
        <figcaption>
          <strong>{b.advisorName}</strong>
          <span>{b.advisorTitle}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">How we help</p>
      <h2>Everything you need, handled with care</h2>
      <div class="grid cols-4" style="margin-top:1.6rem;">
        {props.map((p) => (
          <div class="card prop"><h3>{p.t}</h3><p class="muted">{p.d}</p></div>
        ))}
      </div>
      <p class="allcost">All at no cost to you.</p>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <p class="eyebrow">How it works</p>
      <h2>Get the right Medicare plan in 3 steps</h2>
      <div class="grid cols-3" style="margin-top:1.6rem;">
        {steps.map((s) => (
          <div class="card"><div class="statbig">{s.n}</div><h3>{s.t}</h3><p class="muted">{s.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Our services</p>
      <h2>Explore services, plans & options</h2>
      <div class="grid cols-3" style="margin-top:1.6rem;">
        {services.map(([t, d]) => (<div class="card"><h3>{t}</h3><p class="muted">{d}</p></div>))}
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="wrap">
      <p class="eyebrow">Coverage</p>
      <h2>Medicare products we offer</h2>
      <div class="grid cols-3" style="margin-top:1.4rem;">
        {products.map((p) => (<div class="card pill"><h3>{p}</h3></div>))}
      </div>
      <p style="margin-top:1.8rem;"><a class="btn btn-primary" href="/medicare-advantage-plans">Explore plans & coverage →</a></p>
    </div>
  </section>

  <section class="section invert consult">
    <div class="wrap center">
      <p class="eyebrow">Benefit from decades of experience</p>
      <h2 style="color:#fff;">Your personal Medicare &amp; insurance consultant</h2>
      <p style="color:var(--navy-200);max-width:62ch;margin:0 auto 1.6rem;">{b.advisorName} brings a unique and broad understanding of Medicare and other senior coverages — and the patience to make sure you understand every option before you decide.</p>
      <a class="btn btn-on-dark" href="/about">Meet {b.advisorName} →</a>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="blog-head">
        <div>
          <p class="eyebrow">Resources</p>
          <h2>Latest Medicare guidance</h2>
        </div>
        <a class="all-link" href="/blog">All articles →</a>
      </div>
      <div class="home-posts">
        {latest.map((p) => (
          <a class="hpost card" href={`/blog/${p.slug}`}>
            <div class="hthumb"><img src={p.img} alt="" loading="lazy" /></div>
            <span class="hdate">{p.date}</span>
            <h3>{p.title}</h3>
            <p class="muted">{p.excerpt}</p>
            <span class="hread">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft faq">
    <div class="wrap" style="max-width:820px;">
      <p class="eyebrow">Got questions?</p>
      <h2>We have lots of great answers</h2>
      <div style="margin-top:1.4rem;">
        {faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="finalcta">
        <h2>Let&rsquo;s connect</h2>
        <p>Get your free, personalized Medicare roadmap from a local advisor who has your back.</p>
        <div class="finalcta-row">
          <a class="btn btn-accent" href="/contact">Schedule a conversation</a>
          <a class="btn btn-ghost" href={`tel:${b.phoneHref}`}>{b.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero{position:relative;overflow:hidden;padding:clamp(48px,7vw,96px) 0}
    .hero-glow{position:absolute;inset:auto auto 0 -10%;width:60%;height:120%;background:radial-gradient(50% 50% at 50% 50%,rgba(229,179,34,.16),transparent 70%);pointer-events:none}
    .herogrid{position:relative;display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(2rem,5vw,64px);align-items:center}
    .hero-h1{font-size:clamp(46px,6.6vw,88px);line-height:1.02;letter-spacing:-.02em;margin:0 0 1.3rem;color:var(--ink-900)}
    .hero-h1 .hl{color:var(--orange-500);font-weight:700}
    .hero .lede{font-size:clamp(1.1rem,1.4vw,1.3rem);line-height:1.6;color:var(--text-muted);max-width:46ch;margin:0 0 1.8rem}
    .hero .lede strong{color:var(--navy-800)}
    .hero-cta-row{display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1.8rem}
    .hero-trust{display:flex;gap:1.4rem;flex-wrap:wrap}
    .hero-trust .badge{display:inline-flex;align-items:center;gap:.5rem;font-weight:600;font-size:.95rem;color:var(--navy-800)}
    .hero-trust .badge svg{color:var(--teal-600)}
    .hero-photo{margin:0;position:relative}
    .hero-photo img{display:block;width:100%;border-radius:var(--r-xl);box-shadow:var(--shadow-xl);border:6px solid var(--paper)}
    .hero-photo figcaption{position:absolute;left:18px;bottom:18px;display:flex;flex-direction:column;gap:2px;background:rgba(255,255,255,.94);backdrop-filter:blur(6px);padding:.7rem 1.1rem;border-radius:var(--r-md);box-shadow:var(--shadow-md)}
    .hero-photo figcaption strong{font-family:var(--font-display);font-weight:700;color:var(--navy-800);font-size:1.05rem}
    .hero-photo figcaption span{font-size:.85rem;color:var(--text-muted)}
    @media(max-width:820px){.herogrid{grid-template-columns:1fr}.hero-photo{max-width:460px;order:-1}}

    .prop h3{font-size:1.2rem}
    .allcost{margin-top:1.6rem;font-family:var(--font-display);font-weight:600;font-size:1.3rem;color:var(--teal-600)}
    .pill{display:flex;align-items:center;justify-content:center;text-align:center;padding:1.3rem 1.2rem;background:var(--paper)}
    .pill h3{margin:0;font-size:1.1rem;color:var(--navy-800)}

    .consult{border-radius:0}
    .blog-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2rem;gap:1rem}
    .all-link{font-weight:700;font-size:.95rem;color:var(--orange-600);white-space:nowrap}
    .home-posts{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(1.2rem,2.4vw,1.8rem)}
    .hpost{display:block;color:inherit;padding:0;overflow:hidden}
    .hpost:hover{text-decoration:none}
    .hthumb{overflow:hidden;border-radius:var(--r-lg) var(--r-lg) 0 0;margin:-1px -1px 1.1rem}
    .hthumb img{display:block;width:100%;aspect-ratio:3/2;object-fit:cover;transition:transform .5s cubic-bezier(.16,.8,.3,1)}
    .hpost:hover .hthumb img{transform:scale(1.04)}
    .hpost .hdate,.hpost h3,.hpost p,.hpost .hread{padding-left:clamp(1.4rem,2.4vw,2rem);padding-right:clamp(1.4rem,2.4vw,2rem)}
    .hdate{display:block;font-weight:700;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal-600)}
    .hpost h3{font-size:clamp(1.15rem,1.6vw,1.4rem);line-height:1.18;margin:.45rem 0 .5rem}
    .hpost .hread{display:block;font-weight:700;font-size:.9rem;color:var(--orange-600);padding-bottom:clamp(1.4rem,2.4vw,2rem)}
    @media(max-width:860px){.home-posts{grid-template-columns:1fr}}

    .finalcta{background:linear-gradient(135deg,var(--navy-700),var(--navy-800));color:#fff;border-radius:var(--r-xl);padding:clamp(2.4rem,5vw,4rem);text-align:center;box-shadow:var(--shadow-lg);position:relative;overflow:hidden}
    .finalcta::after{content:"";position:absolute;right:-8%;top:-40%;width:46%;height:160%;background:radial-gradient(50% 50% at 50% 50%,rgba(229,179,34,.22),transparent 70%)}
    .finalcta h2{color:#fff;position:relative}
    .finalcta p{color:var(--navy-200);max-width:52ch;margin:0 auto 1.8rem;position:relative}
    .finalcta-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;position:relative}
    .finalcta .btn-ghost{background:transparent;color:#fff;border-color:rgba(255,255,255,.45)}
    .finalcta .btn-ghost:hover{background:rgba(255,255,255,.1);color:#fff;border-color:#fff}
  </style>
</BaseLayout>
